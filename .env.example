# Projeto Supabase do Nova Layer (fonte única da verdade)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (service role) — só usada no servidor: /out (tracking) e /admin.
# Nunca expor em client component. Obter em: Project Settings -> API Keys.
SUPABASE_SECRET_KEY=

# E-mail do único usuário admin (Supabase Auth). Cinto extra do /admin.
ADMIN_EMAIL=

# Chave da API do Claude para o pipeline de síntese (scripts/synthesize.ts).
ANTHROPIC_API_KEY=
